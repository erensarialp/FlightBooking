@model Dictionary<string, double>

@{
    ViewData["Title"] = "No-Show Analizi";
    Layout = "~/Areas/Admin/Views/Layout/AdminLayout.cshtml";

    @* ── Razor tarafında KPI hesapları ── *@
    double avgNoShow = Model.Count > 0 ? Model.Values.Average() : 0;
    var riskiest = Model.Count > 0 ? Model.OrderByDescending(x => x.Value).First() : new KeyValuePair<string, double>("—", 0);
    var stablest = Model.Count > 0 ? Model.OrderBy(x => x.Value).First() : new KeyValuePair<string, double>("—", 0);
    @* Overbooking önerisi: no-show oranının %60'ı kadar koltuk fazladan satılabilir *@
    double avgOverbooking = avgNoShow * 0.6;
}

@section Styles {
    <style>
        .ns-page {
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        /* ── Sayfa başlığı ── */
        .ns-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 16px;
        }

        .ns-title {
            font-size: 22px;
            font-weight: 700;
            color: #0f172a;
            margin: 0 0 4px;
            letter-spacing: -.3px;
        }

        .ns-sub {
            font-size: 13px;
            color: #94a3b8;
            margin: 0;
        }

        .ns-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .ns-btn {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 9px 18px;
            border-radius: 9px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all .15s;
            border: none;
            text-decoration: none;
        }

        .ns-btn-primary {
            background: #2563eb;
            color: #fff;
        }

            .ns-btn-primary:hover {
                background: #1d4ed8;
                box-shadow: 0 4px 14px rgba(37,99,235,.28);
                color: #fff;
            }

        .ns-btn-outline {
            background: #fff;
            color: #475569;
            border: 1.5px solid #e2e8f0;
        }

            .ns-btn-outline:hover {
                border-color: #94a3b8;
                color: #0f172a;
                background: #f8fafc;
            }

        /* ── KPI Cards ── */
        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 16px;
        }

        .kpi-card {
            background: #fff;
            border: 1px solid #e8edf5;
            border-radius: 14px;
            padding: 20px 22px;
            box-shadow: 0 1px 4px rgba(15,23,42,.05);
            display: flex;
            flex-direction: column;
            gap: 14px;
            transition: box-shadow .18s, transform .18s;
            position: relative;
            overflow: hidden;
        }

            .kpi-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 3px;
                border-radius: 14px 14px 0 0;
            }

            .kpi-card:hover {
                box-shadow: 0 6px 22px rgba(15,23,42,.09);
                transform: translateY(-2px);
            }

        .kpi-card-blue::before {
            background: linear-gradient(90deg,#2563eb,#60a5fa);
        }

        .kpi-card-red::before {
            background: linear-gradient(90deg,#dc2626,#f87171);
        }

        .kpi-card-green::before {
            background: linear-gradient(90deg,#16a34a,#4ade80);
        }

        .kpi-card-orange::before {
            background: linear-gradient(90deg,#d97706,#fbbf24);
        }

        .kpi-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .kpi-lbl {
            font-size: 11.5px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .7px;
            color: #94a3b8;
        }

        .kpi-ico {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

        .kpi-val {
            font-size: 30px;
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -.6px;
            line-height: 1;
        }

            .kpi-val span {
                font-size: 15px;
                font-weight: 500;
                color: #94a3b8;
                margin-left: 2px;
            }

        .kpi-foot {
            font-size: 12px;
            color: #64748b;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .kpi-badge {
            display: inline-flex;
            align-items: center;
            gap: 3px;
            font-size: 11.5px;
            font-weight: 600;
            padding: 2px 8px;
            border-radius: 5px;
        }

        .kb-red {
            background: #fef2f2;
            color: #dc2626;
        }

        .kb-green {
            background: #f0fdf4;
            color: #16a34a;
        }

        .kb-orange {
            background: #fffbeb;
            color: #d97706;
        }

        .kb-blue {
            background: #eff6ff;
            color: #2563eb;
        }

        /* ── Filtre barı ── */
        .ns-filter-bar {
            background: #fff;
            border: 1px solid #e8edf5;
            border-radius: 12px;
            padding: 14px 18px;
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
            box-shadow: 0 1px 3px rgba(15,23,42,.04);
        }

        .ns-filter-lbl {
            font-size: 12.5px;
            font-weight: 600;
            color: #475569;
            white-space: nowrap;
        }

        .ns-chips {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .ns-chip {
            padding: 5px 13px;
            border-radius: 99px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            border: 1.5px solid #e2e8f0;
            background: #f8fafc;
            color: #64748b;
            transition: all .13s;
            user-select: none;
        }

            .ns-chip.active, .ns-chip:hover {
                background: #eff6ff;
                border-color: #bfdbfe;
                color: #2563eb;
            }

        .ns-search {
            margin-left: auto;
            position: relative;
        }

            .ns-search i {
                position: absolute;
                left: 11px;
                top: 50%;
                transform: translateY(-50%);
                color: #94a3b8;
                font-size: 13px;
            }

            .ns-search input {
                padding: 7px 12px 7px 32px;
                border-radius: 8px;
                border: 1.5px solid #e2e8f0;
                font-size: 13px;
                color: #0f172a;
                background: #f8fafc;
                outline: none;
                width: 200px;
                transition: border-color .15s;
            }

                .ns-search input:focus {
                    border-color: #93c5fd;
                    background: #fff;
                }

        /* ── Tablo kartı ── */
        .ns-table-card {
            background: #fff;
            border: 1px solid #e8edf5;
            border-radius: 14px;
            box-shadow: 0 1px 4px rgba(15,23,42,.05);
            overflow: hidden;
        }

        .ns-table-head {
            padding: 16px 22px;
            border-bottom: 1px solid #f1f5f9;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            background: #fafbfd;
        }

        .ns-table-title {
            font-size: 14px;
            font-weight: 700;
            color: #0f172a;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .ns-table-title i {
                color: #2563eb;
            }

        .ns-rec-count {
            font-size: 12px;
            color: #94a3b8;
            font-weight: 500;
        }

        .ns-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

            .ns-table thead tr {
                background: #f8fafc;
                border-bottom: 2px solid #f1f5f9;
            }

            .ns-table thead th {
                padding: 11px 16px;
                font-size: 11px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: .6px;
                color: #94a3b8;
                text-align: left;
                white-space: nowrap;
            }

            .ns-table tbody tr {
                border-bottom: 1px solid #f8fafc;
                transition: background .13s;
            }

                .ns-table tbody tr:last-child {
                    border-bottom: none;
                }

                .ns-table tbody tr:hover {
                    background: #fafbfd;
                }

            .ns-table td {
                padding: 14px 16px;
                vertical-align: middle;
                color: #334155;
            }

        /* Slot kolonu */
        .slot-cell {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .slot-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .slot-name {
            font-weight: 700;
            color: #0f172a;
            font-size: 13.5px;
        }

        /* No-show % göstergesi */
        .ns-pct-wrap {
            display: flex;
            align-items: center;
            gap: 10px;
            min-width: 130px;
        }

        .ns-bar-bg {
            flex: 1;
            height: 6px;
            background: #f1f5f9;
            border-radius: 99px;
            overflow: hidden;
        }

        .ns-bar-fill {
            height: 100%;
            border-radius: 99px;
        }

        .ns-pct-lbl {
            font-size: 13px;
            font-weight: 700;
            min-width: 40px;
            text-align: right;
        }

        /* Risk badge */
        .risk-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 11.5px;
            font-weight: 700;
        }

        .risk-high {
            background: #fef2f2;
            color: #dc2626;
            border: 1px solid #fecaca;
        }

        .risk-medium {
            background: #fffbeb;
            color: #d97706;
            border: 1px solid #fde68a;
        }

        .risk-low {
            background: #f0fdf4;
            color: #16a34a;
            border: 1px solid #bbf7d0;
        }

        /* Overbooking önerisi */
        .ob-pill {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 11px;
            border-radius: 99px;
            font-size: 12.5px;
            font-weight: 700;
            background: #eff6ff;
            color: #2563eb;
            border: 1px solid #bfdbfe;
        }

        /* Risk durumu mini bar */
        .risk-meter {
            display: flex;
            gap: 3px;
            align-items: center;
        }

        .rm-seg {
            height: 14px;
            width: 22px;
            border-radius: 3px;
            background: #f1f5f9;
            transition: background .2s;
        }

        /* ── Insights ── */
        .ins-grid {
            display: grid;
            grid-template-columns: repeat(3,1fr);
            gap: 14px;
        }

        .ins-card {
            background: #fff;
            border: 1px solid #e8edf5;
            border-radius: 12px;
            padding: 16px 18px;
            display: flex;
            gap: 13px;
            align-items: flex-start;
            box-shadow: 0 1px 3px rgba(15,23,42,.04);
            transition: box-shadow .15s, transform .15s;
        }

            .ins-card:hover {
                box-shadow: 0 4px 16px rgba(15,23,42,.08);
                transform: translateY(-1px);
            }

        .ins-ico {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

        .ins-title {
            font-size: 13px;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 4px;
        }

        .ins-desc {
            font-size: 12px;
            color: #64748b;
            line-height: 1.55;
        }

        .ins-tag {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            margin-top: 8px;
            padding: 2px 8px;
            border-radius: 5px;
            font-size: 11px;
            font-weight: 600;
        }

        /* ── Section title ── */
        .ns-sec-title {
            font-size: 15px;
            font-weight: 700;
            color: #0f172a;
            margin: 0 0 14px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .ns-sec-title i {
                color: #2563eb;
                font-size: 14px;
            }

        /* ── Responsive ── */
        @@media (max-width:1100px) {
            .kpi-grid {
                grid-template-columns: repeat(2,1fr);
            }

            .ins-grid {
                grid-template-columns: repeat(2,1fr);
            }
        }

        @@media (max-width:640px) {
            .kpi-grid {
                grid-template-columns: 1fr;
            }

            .ins-grid {
                grid-template-columns: 1fr;
            }

            .ns-search input {
                width: 140px;
            }
        }
    </style>
}

<main class="main-content" id="main-content">
    <div class="container-fluid px-4 py-4">
        <div class="ns-page">

            @* ── Sayfa Başlığı ── *@
            <div class="ns-header">
                <div>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-1" style="font-size:12.5px;">
                            <li class="breadcrumb-item"><a href="#" class="text-decoration-none text-muted">Dashboard</a></li>
                            <li class="breadcrumb-item active">No-Show Analizi</li>
                        </ol>
                    </nav>
                    <h2 class="ns-title">AI Destekli No-Show Analizi</h2>
                    <p class="ns-sub">
                        <i class="bi bi-robot me-1"></i>
                        Slot bazlı no-show tahminleri &bull; @Model.Count uçuş slotu analiz edildi
                    </p>
                </div>
                <div class="ns-actions">
                    <button class="ns-btn ns-btn-outline" onclick="exportCSV()">
                        <i class="bi bi-download"></i> Export CSV
                    </button>
                    <button class="ns-btn ns-btn-primary">
                        <i class="bi bi-stars"></i> AI Risk Report
                    </button>
                </div>
            </div>

            @* ── KPI Cards ── *@
            <div class="kpi-grid">

                <div class="kpi-card kpi-card-blue">
                    <div class="kpi-top">
                        <div class="kpi-lbl">Ortalama No-Show</div>
                        <div class="kpi-ico" style="background:#eff6ff;color:#2563eb;">
                            <i class="bi bi-percent"></i>
                        </div>
                    </div>
                    <div class="kpi-val">%@avgNoShow.ToString("0.0")</div>
                    <div class="kpi-foot">
                        <span class="kpi-badge @(avgNoShow >= 7 ? "kb-red" : avgNoShow >= 5 ? "kb-orange" : "kb-green")">
                            @(avgNoShow >= 7 ? "Yüksek Risk" : avgNoShow >= 5 ? "Orta Risk" : "Kontrollü")
                        </span>
                        tüm slotlar geneli
                    </div>
                </div>

                <div class="kpi-card kpi-card-red">
                    <div class="kpi-top">
                        <div class="kpi-lbl">En Riskli Slot</div>
                        <div class="kpi-ico" style="background:#fef2f2;color:#dc2626;">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                        </div>
                    </div>
                    <div class="kpi-val" style="font-size:20px;margin-top:4px;">@riskiest.Key</div>
                    <div class="kpi-foot">
                        <span class="kpi-badge kb-red"><i class="bi bi-arrow-up" style="font-size:10px;"></i> %@riskiest.Value.ToString("0.0")</span>
                        en yüksek no-show oranı
                    </div>
                </div>

                <div class="kpi-card kpi-card-green">
                    <div class="kpi-top">
                        <div class="kpi-lbl">En Stabil Slot</div>
                        <div class="kpi-ico" style="background:#f0fdf4;color:#16a34a;">
                            <i class="bi bi-shield-check-fill"></i>
                        </div>
                    </div>
                    <div class="kpi-val" style="font-size:20px;margin-top:4px;">@stablest.Key</div>
                    <div class="kpi-foot">
                        <span class="kpi-badge kb-green"><i class="bi bi-arrow-down" style="font-size:10px;"></i> %@stablest.Value.ToString("0.0")</span>
                        en düşük no-show oranı
                    </div>
                </div>

                <div class="kpi-card kpi-card-orange">
                    <div class="kpi-top">
                        <div class="kpi-lbl">Ort. Overbooking Riski</div>
                        <div class="kpi-ico" style="background:#fffbeb;color:#d97706;">
                            <i class="bi bi-airplane-fill"></i>
                        </div>
                    </div>
                    <div class="kpi-val">%@avgOverbooking.ToString("0.0")</div>
                    <div class="kpi-foot">
                        <span class="kpi-badge kb-orange"><i class="bi bi-info-circle" style="font-size:10px;"></i> Öneri</span>
                        önerilen overbooking oranı
                    </div>
                </div>

            </div>

            @* ── Filtre Barı ── *@
            <div class="ns-filter-bar">
                <span class="ns-filter-lbl"><i class="bi bi-funnel me-1"></i> Filtrele:</span>
                <div class="ns-chips">
                    <span class="ns-chip active" onclick="filterRows('all',this)">Tümü</span>
                    <span class="ns-chip" onclick="filterRows('high',this)">
                        <i class="bi bi-circle-fill" style="font-size:7px;color:#dc2626;"></i> Yüksek Risk
                    </span>
                    <span class="ns-chip" onclick="filterRows('medium',this)">
                        <i class="bi bi-circle-fill" style="font-size:7px;color:#d97706;"></i> Orta Risk
                    </span>
                    <span class="ns-chip" onclick="filterRows('low',this)">
                        <i class="bi bi-circle-fill" style="font-size:7px;color:#16a34a;"></i> Düşük Risk
                    </span>
                </div>
                <div class="ns-search">
                    <i class="bi bi-search"></i>
                    <input type="text" placeholder="Slot ara..." oninput="searchRows(this.value)" />
                </div>
            </div>

            @* ── Ana Tablo ── *@
            <div class="ns-table-card">
                <div class="ns-table-head">
                    <div class="ns-table-title">
                        <i class="bi bi-table"></i>
                        Slot Bazlı No-Show Analizi
                    </div>
                    <span class="ns-rec-count" id="recCount">@Model.Count kayıt</span>
                </div>
                <div style="overflow-x:auto;">
                    <table class="ns-table" id="nsTable">
                        <thead>
                            <tr>
                                <th>Flight Slot</th>
                                <th style="min-width:160px;">Ortalama No-Show %</th>
                                <th>Risk Seviyesi</th>
                                <th>Önerilen Overbooking</th>
                                <th>Risk Durumu</th>
                                <th>Operasyon Notu</th>
                            </tr>
                        </thead>
                        <tbody>

                            @* ── foreach aynen korundu ── *@
                            @foreach (var item in Model)
                            {
                                @* Risk hesabı *@
                                string riskLvl = item.Value >= 7 ? "high" : item.Value >= 5 ? "medium" : "low";
                                string riskLabel = item.Value >= 7 ? "Yüksek" : item.Value >= 5 ? "Orta" : "Düşük";
                                string riskClass = item.Value >= 7 ? "risk-high" : item.Value >= 5 ? "risk-medium" : "risk-low";
                                string riskIcon = item.Value >= 7 ? "bi-fire" : item.Value >= 5 ? "bi-dash-circle" : "bi-check-circle";
                                string barColor = item.Value >= 7 ? "#dc2626" : item.Value >= 5 ? "#d97706" : "#16a34a";
                                string dotColor = item.Value >= 7 ? "#dc2626" : item.Value >= 5 ? "#d97706" : "#16a34a";

                                @* Overbooking önerisi: no-show * 0.6 *@
                                double obSuggestion = Math.Round(item.Value * 0.6, 1);

                                @* Progress bar genişliği: max %15 üzerinden oranla *@
                                double barWidth = Math.Min(item.Value / 15.0 * 100, 100);

                                @* Risk meter: 3 segment *@
                                string seg1 = item.Value >= 1 ? barColor : "#f1f5f9";
                                string seg2 = item.Value >= 5 ? barColor : "#f1f5f9";
                                string seg3 = item.Value >= 7 ? barColor : "#f1f5f9";

                                @* Operasyon notu *@
                                string opNote = item.Value >= 7
                                ? "Agresif overbooking + ekstra standby önerilir."
                                : item.Value >= 5
                                ? "Kontrollü overbooking uygulanabilir."
                                : "Standart operasyon yeterli.";

                                <tr class="ns-row" data-risk="@riskLvl" data-slot="@item.Key.ToLower()">
                                    <td>
                                        <div class="slot-cell">
                                            <div class="slot-dot" style="background:@dotColor;box-shadow:0 0 0 3px @dotColor\22;"></div>
                                            <span class="slot-name">@item.Key</span>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="ns-pct-wrap">
                                            <div class="ns-bar-bg">
                                                <div class="ns-bar-fill"
                                                     style="width:@barWidth.ToString("0", System.Globalization.CultureInfo.InvariantCulture)%;background:@barColor;">
                                                </div>
                                            </div>
                                            <span class="ns-pct-lbl" style="color:@barColor;">
                                                %@item.Value.ToString("0.0")
                                            </span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="risk-badge @riskClass">
                                            <i class="bi @riskIcon" style="font-size:10px;"></i>
                                            @riskLabel
                                        </span>
                                    </td>
                                    <td>
                                        <span class="ob-pill">
                                            <i class="bi bi-plus-circle" style="font-size:10px;"></i>
                                            %@obSuggestion.ToString("0.0")
                                        </span>
                                    </td>
                                    <td>
                                        <div class="risk-meter">
                                            <div class="rm-seg" style="background:@seg1;" title="Düşük"></div>
                                            <div class="rm-seg" style="background:@seg2;" title="Orta"></div>
                                            <div class="rm-seg" style="background:@seg3;" title="Yüksek"></div>
                                        </div>
                                    </td>
                                    <td>
                                        <span style="font-size:12px;color:#64748b;display:flex;align-items:center;gap:5px;">
                                            <i class="bi bi-lightbulb-fill" style="color:#2563eb;font-size:11px;flex-shrink:0;"></i>
                                            @opNote
                                        </span>
                                    </td>
                                </tr>
                            }

                        </tbody>
                    </table>
                </div>
            </div>

            @* ── AI Operational Insights ── *@
            <div>
                <h3 class="ns-sec-title">
                    <i class="bi bi-lightbulb-fill"></i>
                    AI Operational Insights
                    <span style="font-size:11px;font-weight:500;color:#94a3b8;margin-left:4px;">AI destekli operasyon önerileri</span>
                </h3>
                <div class="ins-grid">

                    <div class="ins-card">
                        <div class="ins-ico" style="background:#fef2f2;color:#dc2626;">
