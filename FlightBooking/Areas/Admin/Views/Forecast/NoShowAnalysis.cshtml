@section Scripts {
    <script>
        /* ── Filtre ── */
        function filterRows(type, btn) {
            document.querySelectorAll('.ns-chip').forEach(function(c){ c.classList.remove('active'); });
            btn.classList.add('active');
            var rows    = document.querySelectorAll('#nsTable tbody .ns-row');
            var visible = 0;
            rows.forEach(function(row) {
                var show = type === 'all' || row.dataset.risk === type;
                row.style.display = show ? '' : 'none';
                if (show) visible++;
            });
            document.getElementById('recCount').textContent = visible + ' kayıt';
        }

        /* ── Arama ── */
        function searchRows(val) {
            var rows    = document.querySelectorAll('#nsTable tbody .ns-row');
            var visible = 0;
            val = val.toLowerCase();
            rows.forEach(function(row) {
                var show = val === '' || (row.dataset.slot || '').includes(val);
                row.style.display = show ? '' : 'none';
                if (show) visible++;
            });
            document.getElementById('recCount').textContent = visible + ' kayıt';
        }

        /* ── Export CSV ── */
        function exportCSV() {
            var rows  = document.querySelectorAll('#nsTable tbody .ns-row');
            var lines = ['Flight Slot,No-Show %,Risk Seviyesi,Önerilen Overbooking'];
            rows.forEach(function(row) {
                if (row.style.display === 'none') return;
                var cells = row.querySelectorAll('td');
                var slot  = row.dataset.slot || '';
                var pct   = cells[1] ? cells[1].textContent.trim().replace(/\s+/g,' ') : '';
                var risk  = cells[2] ? cells[2].textContent.trim() : '';
                var ob    = cells[3] ? cells[3].textContent.trim() : '';
                lines.push([slot, pct, risk, ob].join(','));
            });
            var blob = new Blob([lines.join('\n')], { type:'text/csv;charset=utf-8;' });
            var url  = URL.createObjectURL(blob);
            var a    = document.createElement('a');
            a.href   = url; a.download = 'noshow-analiz.csv'; a.click();
            URL.revokeObjectURL(url);
        }
    </script>
}
